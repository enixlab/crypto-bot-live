# =========================================
# HYPERLIQUID
# =========================================
# Clé privée de l'API wallet (générée sur https://app.hyperliquid.xyz/API)
# ⚠️ JAMAIS commit. JAMAIS ton MetaMask seed. JAMAIS partager.
HYPERLIQUID_PRIVATE_KEY=0x...

# Adresse publique de ton compte principal Hyperliquid (celui qui détient le collateral)
# Format: 0x... (42 chars, ton wallet MetaMask)
HYPERLIQUID_ACCOUNT_ADDRESS=0x...

# Réseau: "testnet" (dev) ou "mainnet" (prod, vrai argent)
HYPERLIQUID_NETWORK=testnet

# =========================================
# LLM SENTIMENT
# =========================================
# DeepSeek (primary)
DEEPSEEK_API_KEY=sk-...

# Gemini (fallback gratuit)
GEMINI_API_KEY=...

# Modèle à utiliser (deepseek-chat ou gemini-2.5-flash)
SENTIMENT_MODEL=deepseek-chat

# =========================================
# NEWS SOURCES
# =========================================
CRYPTONEWS_API_KEY=
CRYPTOPANIC_API_KEY=

# =========================================
# BOT CONFIG
# =========================================
BOT_KEY=sentiment_v1
BOT_NAME=Sentiment V1
INITIAL_CAPITAL=1000
LEVERAGE=3
KILL_SWITCH_DD_PCT=-0.15
CYCLE_MINUTES=10

# =========================================
# STORAGE (Cloud Run)
# =========================================
GCS_BUCKET=enix-crypto-bot-state
GCS_STATE_PREFIX=data/

# =========================================
# ALERTING
# =========================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
